{
  "title": "Laravel App",
  "uid": "laravel-app",
  "version": 1,
  "tags": ["laravel"],
  "schemaVersion": 36,
  "panels": [
    {
      "id": 1,
      "title": "Requests per second",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "targets": [{
        "expr": "sum(rate(app_requests_total[1m]))",
        "legendFormat": "rps"
      }]
    },
    {
      "id": 2,
      "title": "Error rate",
      "type": "stat",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "targets": [{
        "expr": "sum(rate(app_errors_total[1m]))",
        "legendFormat": "errors/s"
      }]
    },
    {
      "id": 3,
      "title": "Error %",
      "type": "stat",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "targets": [{
        "expr": "sum(rate(app_errors_total[1m])) / sum(rate(app_requests_total[1m])) * 100",
        "legendFormat": "%"
      }]
    },
    {
      "id": 4,
      "title": "Response time p95",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(app_response_time_seconds_bucket[5m])) by (le))",
        "legendFormat": "p95"
      }]
    },
    {
      "id": 5,
      "title": "Response time p99",
      "type": "stat",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(app_response_time_seconds_bucket[5m])) by (le))",
        "legendFormat": "p99"
      }]
    },
    {
      "id": 6,
      "title": "Horizon status",
      "type": "stat",
      "gridPos": {"x": 20, "y": 0, "w": 4, "h": 4},
      "targets": [{
        "expr": "app_horizon_status",
        "legendFormat": "status"
      }]
    },
    {
      "id": 7,
      "title": "Requests (1m rate)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 5, "w": 12, "h": 8},
      "targets": [{
        "expr": "sum(rate(app_requests_total[1m])) by (status)",
        "legendFormat": "{{status}}"
      }]
    },
    {
      "id": 8,
      "title": "Response time p50/p95/p99",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 5, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(app_response_time_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(app_response_time_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(app_response_time_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 9,
      "title": "Error rate by status",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 14, "w": 12, "h": 8},
      "targets": [{
        "expr": "sum(rate(app_errors_total[1m])) by (status)",
        "legendFormat": "{{status}}"
      }]
    },
    {
      "id": 10,
      "title": "Job queue size",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 14, "w": 4, "h": 8},
      "targets": [{
        "expr": "app_queue_size_total",
        "legendFormat": "{{queue}}"
      }]
    },
    {
      "id": 11,
      "title": "Failed jobs / hour",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 14, "w": 4, "h": 8},
      "targets": [{
        "expr": "app_failed_jobs_per_hour",
        "legendFormat": "failed"
      }]
    },
    {
      "id": 12,
      "title": "Jobs / minute",
      "type": "timeseries",
      "gridPos": {"x": 20, "y": 14, "w": 4, "h": 8},
      "targets": [{
        "expr": "app_jobs_per_minute",
        "legendFormat": "jobs/min"
      }]
    }
  ]
}
